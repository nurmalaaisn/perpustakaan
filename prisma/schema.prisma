// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PETUGAS
  MEMBER
}

model Student {
  id       Int      @id @default(autoincrement())
  nis      String?  @unique
  name     String
  email    String   @unique
  kelas    String?
  jurusan  String?
  password String
  role     UserRole

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  peminjamanBukus PeminjamanBuku[]
}

model Walas {
  id_walas   Int      @id @default(autoincrement())
  nis        String   @unique
  name_walas String
  no_telp    String
  alamat     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Buku {
  id     Int    @id @default(autoincrement())
  title  String
  author String
  year   Int
  stok   Int    @default(0)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  peminjamanBukus PeminjamanBuku[]
}

model PeminjamanBuku {
  id_peminjaman Int    @id @default(autoincrement())
  nis           String?
  id_buku       Int

  student Student? @relation(fields: [nis], references: [nis])
  buku    Buku    @relation(fields: [id_buku], references: [id])

  tanggal_pinjam  DateTime @default(now())
  tenggat_kembali DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pengembalians Pengembalian[]
}

model Pengembalian {
  id_pengembalian Int            @id @default(autoincrement())
  id_peminjaman   Int
  peminjamanBuku  PeminjamanBuku @relation(fields: [id_peminjaman], references: [id_peminjaman])

  tanggal_kembali DateTime @default(now())
  denda           Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
